<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Wizard form view -->
    <record id="acb_fetch_wizard_form_view" model="ir.ui.view">
        <field name="name">acb.fetch.wizard.form</field>
        <field name="model">acb.fetch.wizard</field>
        <field name="arch" type="xml">
            <form string="Lấy giao dịch ACB">
                <group>
                    <field name="config_id"/>
                    <field name="date_range" widget="radio"/>
                </group>
                
                <group string="Khoảng thời gian" attrs="{'invisible': [('date_range', '!=', 'custom')]}">
                    <group>
                        <field name="from_date"/>
                        <field name="to_date"/>
                    </group>
                </group>
                
                <group string="Tùy chọn">
                    <field name="auto_process"/>
                </group>
                
                <group string="Kết quả" attrs="{'invisible': [('fetched_count', '=', 0)]}">
                    <field name="fetched_count"/>
                    <field name="error_message" attrs="{'invisible': [('error_message', '=', False)]}"/>
                </group>
                
                <footer>
                    <button name="action_fetch_transactions" string="Lấy giao dịch" type="object" class="btn-primary"/>
                    <button name="action_view_transactions" string="Xem giao dịch" type="object" class="btn-secondary" attrs="{'invisible': [('fetched_count', '=', 0)]}"/>
                    <button name="action_close" string="Đóng" type="object" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Wizard action -->
    <record id="acb_fetch_wizard_action" model="ir.actions.act_window">
        <field name="name">Lấy giao dịch ACB</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">acb.fetch.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="view_id" ref="acb_fetch_wizard_form_view"/>
    </record>
</odoo> 