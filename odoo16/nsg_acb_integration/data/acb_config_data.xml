        <!-- System Parameters -->
        <record id="acb_webhook_timeout" model="ir.config_parameter">
            <field name="key">acb.webhook.timeout</field>
            <field name="value">30</field>
        </record>

        <record id="acb_auto_process" model="ir.config_parameter">
            <field name="key">acb.auto_process</field>
            <field name="value">True</field>
        </record>

        <record id="acb_logging_enabled" model="ir.config_parameter">
            <field name="key">acb.logging.enabled</field>
            <field name="value">True</field>
        </record>

        <record id="acb_max_retries" model="ir.config_parameter">
            <field name="key">acb.max_retries</field>
            <field name="value">3</field>
        </record>

        <record id="acb_api_rate_limit" model="ir.config_parameter">
            <field name="key">acb.api.rate_limit</field>
            <field name="value">100</field>
        </record>

        <record id="acb_webhook_secret" model="ir.config_parameter">
            <field name="key">acb.webhook.secret</field>
            <field name="value">acb_webhook_secret_2024</field>
        </record>

        <!-- Email template for transaction errors -->
        <record id="acb_transaction_error_email_template" model="mail.template">
            <field name="name">ACB Transaction Error Notification</field>
            <field name="model_id" ref="model_acb_transaction"/>
            <field name="subject">⚠️ Lỗi giao dịch ACB - ${object.transaction_code}</field>
            <field name="email_from">${user.email_formatted}</field>
            <field name="email_to">${object.company_id.email}</field>
            <field name="body_html"><![CDATA[
                <div style="margin: 0px; padding: 0px; font-family: Arial, sans-serif;">
                    <h2 style="color: #dc3545;">🚨 Lỗi Giao Dịch ACB</h2>
                    <p>Xin chào,</p>
                    <p>Có lỗi xảy ra khi xử lý giao dịch ACB:</p>
                    <table style="border-collapse: collapse; width: 100%; margin: 20px 0;">
                        <tr style="background-color: #f8f9fa;">
                            <td style="border: 1px solid #ddd; padding: 8px; font-weight: bold;">Mã giao dịch:</td>
                            <td style="border: 1px solid #ddd; padding: 8px;">${object.transaction_code}</td>
                        </tr>
                        <tr>
                            <td style="border: 1px solid #ddd; padding: 8px; font-weight: bold;">Số tiền:</td>
                            <td style="border: 1px solid #ddd; padding: 8px;">${object.amount_in_currency} ${object.currency_id.name}</td>
                        </tr>
                        <tr style="background-color: #f8f9fa;">
                            <td style="border: 1px solid #ddd; padding: 8px; font-weight: bold;">Thời gian:</td>
                            <td style="border: 1px solid #ddd; padding: 8px;">${object.transaction_date}</td>
                        </tr>
                        <tr>
                            <td style="border: 1px solid #ddd; padding: 8px; font-weight: bold;">Nguồn:</td>
                            <td style="border: 1px solid #ddd; padding: 8px;">${object.source_type}</td>
                        </tr>
                        <tr style="background-color: #f8f9fa;">
                            <td style="border: 1px solid #ddd; padding: 8px; font-weight: bold;">Nội dung:</td>
                            <td style="border: 1px solid #ddd; padding: 8px;">${object.transaction_content}</td>
                        </tr>
                        <tr style="background-color: #ffebee;">
                            <td style="border: 1px solid #ddd; padding: 8px; font-weight: bold; color: #dc3545;">Lỗi:</td>
                            <td style="border: 1px solid #ddd; padding: 8px; color: #dc3545;">${object.error_message}</td>
                        </tr>
                    </table>
                    <p><strong>Hành động cần thiết:</strong></p>
                    <ul>
                        <li>Kiểm tra log hệ thống để biết thêm chi tiết</li>
                        <li>Xác minh kết nối API ACB</li>
                        <li>Xử lý giao dịch thủ công nếu cần</li>
                    </ul>
                    <p>Trân trọng,<br/>
                    <strong>Hệ thống ACB Integration</strong><br/>
                    <em>NSG ERP Team</em></p>
                </div>
            ]]></field>
        </record>

        <!-- Email template for API connection errors -->
        <record id="acb_api_error_email_template" model="mail.template">
            <field name="name">ACB API Connection Error</field>
            <field name="model_id" ref="model_acb_config"/>
            <field name="subject">🔌 Lỗi kết nối ACB API - ${object.name}</field>
            <field name="email_from">${user.email_formatted}</field>
            <field name="email_to">${object.company_id.email}</field>
            <field name="body_html"><![CDATA[
                <div style="margin: 0px; padding: 0px; font-family: Arial, sans-serif;">
                    <h2 style="color: #dc3545;">🔌 Lỗi Kết Nối ACB API</h2>
                    <p>Xin chào,</p>
                    <p>Hệ thống không thể kết nối đến ACB API:</p>
                    <ul>
                        <li><strong>Cấu hình:</strong> ${object.name}</li>
                        <li><strong>Client ID:</strong> ${object.client_id}</li>
                        <li><strong>API URL:</strong> ${object.api_notification_url}</li>
                        <li><strong>Thời gian:</strong> ${datetime.datetime.now()}</li>
                    </ul>
                    <p>Vui lòng kiểm tra kết nối mạng và cấu hình API.</p>
                    <p>Trân trọng,<br/>Hệ thống ACB Integration</p>
                </div>
            ]]></field>
        </record>

    </data>
</odoo> 