<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_account_partner_reconciliation_form" model="ir.ui.view">
        <field name="name">account.partner.reconciliation.form</field>
        <field name="model">account.partner.reconciliation</field>
        <field name="arch" type="xml">
            <form string="Biên bản đối chiếu công nợ">
                <field name="word_file" attrs="{'invisible': True}"/>
                <field name="word_filename" attrs="{'invisible': True}"/>
                <div class="alert alert-info" role="alert" attrs="{'invisible': [('word_file', '=', False)]}">
                    <p>Bạn có thể tải xuống tập tin Word đã được tạo bằng cách nhấp vào nút bên dưới:</p>
                    <field name="word_file" readonly="1" filename="word_filename" widget="binary" class="oe_inline"/>
                </div>
                <group>
                    <group>
                        <field name="partner_id" domain="[('parent_id', '=', False)]"/>
                        <field name="company_id" groups="base.group_multi_company"/>
                        <field name="company_currency_id" invisible="1"/>
                    </group>
                    <group>
                        <field name="date_from"/>
                        <field name="date_to"/>
                    </group>
                    <group class="oe_subtotal_footer oe_right">
                        <field name="initial_balance" widget="monetary"/>
                        <field name="debit_amount" widget="monetary"/>
                        <field name="credit_amount" widget="monetary"/>
                        <field name="ending_balance" class="oe_subtotal_footer_separator" widget="monetary"/>
                    </group>
                </group>
                <footer>
                    <!-- <button name="action_print_report" string="In báo cáo PDF" type="object" class="btn-primary" icon="fa-print"/> -->
                    <button name="action_export_word" string="Xuất file Word" type="object" class="btn-primary" icon="fa-file-word-o"/>
                    <button string="Hủy" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_account_partner_reconciliation" model="ir.actions.act_window">
        <field name="name">Biên bản đối chiếu công nợ</field>
        <field name="res_model">account.partner.reconciliation</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_action_account_partner_reconciliation"
        name="Biên bản đối chiếu công nợ"
        parent="account.menu_finance_reports"
        action="action_account_partner_reconciliation"
        sequence="20"/>
</odoo> 