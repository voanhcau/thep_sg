<?xml version="1.0" ?>
<odoo>

    <record id="import_sale_order_config_form" model="ir.ui.view">
        <field name="name">Import Config</field>
        <field name="model">import.sale.order.config</field>
        <field name="priority">1</field>
        <field name="arch" type="xml">
            <tree string="Import Config" editable="bottom">
                <field name="company_id"/>
                <field name="payment_term_id"/>
                <field name="pricelist_id"/>
                <field name="warehouse_id"/>
                <field name="purchase_pricelist_id"/>
            </tree>
        </field>
    </record>

    <record id="action_import_sale_order_config" model="ir.actions.act_window">
        <field name="name">Cấu hình import đơn hàng</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">import.sale.order.config</field>
        <field name="view_mode">tree</field>
    </record>

    <menuitem id="menu_action_import_sale_order_config"
              action="action_import_sale_order_config"
              groups="sales_team.group_sale_manager"
              parent="sale.sale_order_menu"
              sequence="100"/>

</odoo>