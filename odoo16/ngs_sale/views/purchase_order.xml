<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!--
    Các chức năng tuỳ chỉnh đã thêm vào file này:
    1. Đổi tên trường "Đơn hàng" thành "Đơn hàng bán" (sale_id).
    2. Đổi tên trường "Điều khoản thanh toán" thành "Điều khoản TT" (payment_term_id).
    3. Đưa 2 trường "Đơn hàng bán" (sale_id) và "Chi phí của" (sale_reference_id) sang cột bên phải, ngay dưới trường "Điều khoản TT" trong form view.
    4. Thêm trường "Ngày xác nhận" (date_approve) và "Ngày nhận hàng" (expected_date) vào tree view (danh sách các đơn mua hàng).
    -->

    <record id="purchase.purchase_history_tree" model="ir.ui.view">
        <field name="name">purchase.ngs.history.tree</field>
        <field name="model">purchase.order.line</field>
        <field name="arch" type="xml">
            <tree create="false" default_order="order_id asc">
                <field name="order_id" widget="many2one"/>
                <field name="date_planned" widget="date" string="Ngày nhận hàng"/>
                <field name="partner_id"/>
                <field name="categ_id" string="Danh mục sản phẩm"/>
                <field name="product_id"/>
                <field name="product_uom_qty" sum="Tổng KL mua"/>
                <field name="price_unit"/>
                <field name="discount_value"/>
            </tree>
        </field>
    </record>

    <record id="purchase_order_form" model="ir.ui.view">
        <field name="name">purchase.order.form</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='invoice_status']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='invoice_status']" position="before">
                <field name="invoice_status_custom" string="Trạng thái hóa đơn"/>
            </xpath>    
            <xpath expr="//field[@name='picking_type_id']" position="after">
                <field name="default_location_dest_id"/>
            </xpath>
            <xpath expr="//div[@name='button_box']" position="after">
                <field name="advance_state" invisible="True"/>
                <widget name="web_ribbon" title="Đề xuất TU" attrs="{'invisible': [('advance_state', '!=', 'requested')]}"/>
                <widget name="web_ribbon" title="Đã TU" attrs="{'invisible': [('advance_state', '!=', 'advanced')]}"/>
            </xpath>
            <xpath expr="//label[@for='date_approve']" position="attributes">
                <attribute name="attrs">{'invisible': [('state','in',(''))]}</attribute>
            </xpath>
            <xpath expr="//div[@name='date_approve']" position="attributes">
                <attribute name="attrs">{'invisible': [('state','in',(''))]}</attribute>
            </xpath>
            <xpath expr="//field[@name='partner_id']" position="attributes">
                <attribute name="options">{'no_create': True}</attribute>
            </xpath>
            <xpath expr="//field[@name='date_planned']" position="attributes">
                <attribute name="string">Ngày nhận hàng</attribute>
            </xpath>
            <xpath expr="//field[@name='default_location_dest_id']" position="replace"/>
            <xpath expr="//field[@name='payment_term_id']" position="replace">
                <field name="default_location_dest_id"/>
            </xpath>
            <xpath expr="//div[@name='date_planned_div']" position="after">
                <field name="payment_term_id" string="Điều khoản TT"/>
                <field name="sale_id" string="Đơn hàng bán" readonly="1"/>
                <field name="sale_reference_id" string="Chi phí của" readonly="1"/>
            </xpath>
            <xpath expr="//field[@name='sale_id']" position="attributes">
                <attribute name="string">Đơn hàng bán</attribute>
            </xpath>
            <xpath expr="//field[@name='sale_reference_id']" position="attributes">
                <attribute name="string">Chi phí của</attribute>
            </xpath>
            <xpath expr="//field[@name='order_line']/tree/field[@name='product_qty']" position="before">
                <field name="supplier_delivery_type_id" optional="hide"/>
                <field name="quantity_another1" optional="hide"/>
                <field name="quantity_another2" optional="hide"/>
                <field name="quantity_another3" optional="hide"/>
                <field name="length" optional="hide"/>
                <field name="discount_value" optional="hide"/>
            </xpath>
            <xpath expr="//field[@name='order_line']/tree/field[@name='name']" position="attributes">
                <attribute name="optional">hide</attribute>
            </xpath>
            <xpath expr="//field[@name='order_line']/tree/field[@name='product_qty']" position="attributes">
                <attribute name="string">KL(kg)</attribute>
                <attribute name="sum">Tổng KL</attribute>
                <attribute name="widget">float</attribute>
            </xpath>
            <xpath expr="//field[@name='order_line']/tree/field[@name='product_uom']" position="replace"/>
            <xpath expr="//field[@name='order_line']/tree/field[@name='product_uom']" position="replace">
                <field name="product_uom" invisible="1" groups="!uom.group_uom"/>
                <field name="product_uom"
                       groups="uom.group_uom"
                       attrs="{
                                            'readonly': [('state', 'in', ('purchase', 'done', 'cancel'))],
                                            'required': [('display_type', '=', False)]
                                        }"
                       force_save="1" optional="show"/>
            </xpath>
            <xpath expr="//div[hasclass('clearfix')]" position="after">
                <group>
                    <group>
                        <field colspan="4" name="purchase_description" nolabel="1"
                               placeholder="Điều khoản mua hàng ..."/>
                    </group>
                </group>
            </xpath>
            <xpath expr="//field[@name='user_id']" position="replace"/>
            <xpath expr="//field[@name='partner_ref']" position="after">
                <field name="user_id" string="Nhân Viên Kinh Doanh"/>
                <field name="support_user_id"/>
                <field name="sale_type" invisible="1"/>
                <field name="tag_ids"  widget="many2many_tags" options="{'color_field': 'color'}" string="Thẻ"/>
            </xpath>
            <xpath expr="//button[@name='button_cancel']" position="after">
                <button name="force_cancel"
                        groups="purchase.group_purchase_manager"
                        states="draft,to approve,sent,purchase"
                        string="Huỷ đơn"
                        confirm="Vui lòng tạo đơn trả hàng khỏi kho để cân bằng số lượng tồn kho nếu đã nhập kho trước đó"
                        type="object"/>
            </xpath>
            <xpath expr="//header" position="inside">
                <button name="button_propose_advance" 
                    attrs="{'invisible': ['|', ('advance_state', '!=', 'not_requested'), ('state', 'not in', ['draft', 'sent'])]}"
                    string="Đề xuất TU" type="object" class="btn-primary"/>
                <button name="button_confirm_advance" 
                    attrs="{'invisible': ['|', ('advance_state', '!=', 'requested'), ('state', 'not in', ['draft', 'sent'])]}"
                    string="Xác nhận TU" type="object" class="btn-secondary"/>
                <button name="button_cancel_advance" 
                    attrs="{'invisible': [('advance_state', '!=', 'advanced')]}"
                    string="Huỷ TU" type="object" class="btn-secondary"/>
            </xpath>
        </field>
    </record>

    <record id="view_purchase_order_filter" model="ir.ui.view">
        <field name="name">purchase.order.filter.custom</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.view_purchase_order_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//filter[@name='my_purchases']" position="replace">
                <field name="support_user_id"/>
                <field name="tag_ids"/>
                <field name="advance_state"/>
                <filter name="my_purchases" string="Đơn hàng của tôi"
                        domain="['|', ('user_id', '=', uid), ('support_user_id', '=', uid)]"/>
                <filter name="by_tag" string="Lọc theo thẻ" domain="[('tag_ids', '!=', False)]"/>
                <filter name="by_advance_state" string="Lọc theo trạng thái" domain="[('advance_state', '!=', False)]"/>
                <group expand="0" string="Nhóm theo">
                    <filter name="group_by_tag" string="Thẻ" context="{'group_by': 'tag_ids'}"/>
                    <filter name="group_by_advance_state" string="Trạng thái" context="{'group_by': 'advance_state'}"/>
                </group>
            </xpath>
            
        </field>
    </record>

    <record id="purchase_order_tree" model="ir.ui.view">
        <field name="name">purchase.order.tree</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <field name="date_planned" optional="hide" widget="date" string="Ngày nhận hàng"/>
                <field name="picking_type_id" optional="hide" widget="many2one"/>
            </xpath>
            <xpath expr="//tree" position="inside">
                <field name="tag_ids" optional="hide" widget="many2many_tags" options="{'color_field': 'color'}" string="Thẻ"/>
                <field name="advance_state" optional="hide"/>
                <field name="notes" optional="hide" string="Ghi chú"/>
            </xpath>
            <xpath expr="//field[@name='amount_untaxed']" position="before">
                <field name="total_product_qty" optional="hide" sum="Tổng KL (kg)"/>
            </xpath>
        </field>
    </record>

    <record id="purchase_order_kpis_tree" model="ir.ui.view">
        <field name="name">purchase.order.tree</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_kpis_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='invoice_status']" position="replace">
                <field name="payment_term_id" optional="hide" string="Điều khoản TT"/>
                <field name="invoice_status_custom" string="Trạng thái hóa đơn" optional="show"/>
            </xpath>    
            <xpath expr="//tree" position="inside">
                <field name="tag_ids" optional="hide" widget="many2many_tags" options="{'color_field': 'color'}" string="Thẻ"/>
                <field name="advance_state" optional="hide"/>
                <field name="notes" optional="hide" string="Ghi chú"/>
            </xpath>
            <xpath expr="//field[@name='name']" position="after">
                <field name="date_planned" optional="hide" widget="date" string="Ngày nhận hàng"/>
                <field name="picking_type_id" optional="hide" widget="many2one"/>
            </xpath>
            <xpath expr="//field[@name='amount_total']" position="before">
                <field name="total_product_qty" optional="hide" sum="Tổng KL (kg)"/>
            </xpath>
        </field>
    </record>

</odoo>
