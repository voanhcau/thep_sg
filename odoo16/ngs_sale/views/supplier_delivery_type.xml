<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="supplier_delivery_type_form_view" model="ir.ui.view">
        <field name="name">supplier.delivery.type.form</field>
        <field name="model">supplier.delivery.type</field>
        <field name="arch" type="xml">
            <form class="oe_form_configuration">
                <sheet>
                    <div class="oe_title">
                        <label for="name" string="Tên"/>
                        <h1>
                            <field name="name" placeholder="e.g. Bẻ / Thẳng"/>
                        </h1>
                    </div>
                    <group name="first" col="2">
                        <field name="cost_price" class="oe_inline"/>
                        <field name="is_default" class="oe_inline"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="supplier_delivery_type_list_view" model="ir.ui.view">
        <field name="name">supplier.delivery.type.list</field>
        <field name="model">supplier.delivery.type</field>
        <field name="priority">1</field>
        <field name="arch" type="xml">
            <tree string="Quy cách">
                <field name="name"/>
                <field name="cost_price"/>
                <field name="is_default"/>
            </tree>
        </field>
    </record>

    <record id="supplier_delivery_type_search_view" model="ir.ui.view">
        <field name="name">supplier.delivery.type.search</field>
        <field name="model">supplier.delivery.type</field>
        <field name="arch" type="xml">
            <search string="Quy cách">
                <field name="name"/>
            </search>
        </field>
    </record>

    <record id="supplier_delivery_type_action_form" model="ir.actions.act_window">
        <field name="name">Quy cách</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">supplier.delivery.type</field>
        <field name="search_view_id" ref="supplier_delivery_type_search_view"/>
        <field name="view_id" ref="supplier_delivery_type_list_view"/>
    </record>

    <menuitem id="menu_supplier_delivery_type_action_form"
          action="supplier_delivery_type_action_form"
          groups="sales_team.group_sale_manager"
          parent="sale.product_menu_catalog"
          sequence="71"
    />

</odoo>
