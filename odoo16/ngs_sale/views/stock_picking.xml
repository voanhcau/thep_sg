<odoo>
    <!-- Form View: Stock Picking -->
    <record id="view_picking_form" model="ir.ui.view">
        <field name="name">stock.picking.ngs.form</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='date_done']" position="replace"/>
            <xpath expr="//field[@name='origin']" position="after">
                <field name="received_date"/>
                <field name="date_done" readonly="0" string="Ngày hiệu lực"/>
            </xpath>
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="delivery_receipt_construction_site" widget="html"
                       placeholder="Căn cứ báo giá số: ... ký ngày: ... &#10;+ Phiếu giao hàng: ... &#10;Ngày: ..." />
            </xpath>
            <xpath expr="//field[@name='move_ids_without_package']/tree/field[@name='product_id']" position="after">
                <field name="quantity_another1"/>
            </xpath>
        </field>
    </record>

    <!-- Thêm cột SL (quantity_another1) cho tree move_line_ids_without_package -->
    <record id="view_stock_move_line_detailed_operation_tree_qty_another1" model="ir.ui.view">
        <field name="name">stock.move.line.tree.detailed.qty_another1</field>
        <field name="model">stock.move.line</field>
        <field name="inherit_id" ref="stock.view_stock_move_line_detailed_operation_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//tree/field[@name='product_id']" position="after">
                <field name="quantity_another1"/>
            </xpath>
        </field>
    </record>
</odoo>