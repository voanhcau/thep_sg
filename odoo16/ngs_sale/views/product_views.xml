<odoo>
    <record id="product_template_form_inherit_l10n_pe_edi" model="ir.ui.view">
        <field name="name">product.template.form.inherit.l10n_pe_edi</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="account.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='taxes_id']" position="before">
                <field name="quantity_supplier"/>
                <field name="quantity_tcvn"/>
                <field name="quantity_another"/>
                <field name="type"/>
            </xpath>
        </field>
    </record>
</odoo>
